# ============================================================
# OMEN — The Oracle Machine | Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ============================================================

# ---- Application ----
APP_NAME=OMEN
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-me-in-production
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ---- Database ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=omen
POSTGRES_USER=omen_user
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ---- JWT Auth ----
JWT_SECRET_KEY=your-jwt-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# ---- AI / Oracle Engine ----
OPENROUTER_API_KEY=your-openrouter-api-key
ORACLE_MODEL=google/gemini-2.0-flash-exp:free
ORACLE_SWARM_SIZE=1000
ORACLE_DEBATE_ROUNDS=3

# ---- MiroFish Integration ----
MIROFISH_API_URL=http://localhost:5001
MIROFISH_ENABLED=false

# ---- Polymarket ----
POLYMARKET_API_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_PRIVATE_KEY=your-polygon-private-key
POLYMARKET_API_KEY=your-polymarket-api-key
POLYMARKET_API_SECRET=your-polymarket-api-secret
POLYMARKET_PASSPHRASE=your-polymarket-passphrase

# ---- Polygon RPC ----
POLYGON_RPC_URL=https://polygon-rpc.com

# ---- Credits System ----
CREDIT_PRICE_CENTS=10
CREDITS_PER_PURCHASE=50
TRADE_FEE_PERCENT=2.5
WIN_FEE_PERCENT=5.0
REFERRAL_BONUS_PERCENT=10.0

# ---- Twitter/X Bot ----
TWITTER_API_KEY=your-twitter-api-key
TWITTER_API_SECRET=your-twitter-api-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret

# ---- Stripe (Payments) ----
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_ID=your-stripe-price-id
